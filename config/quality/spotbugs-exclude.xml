<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs 排除过滤器
  排除不需要检查的 Bug 类型（如 Lombok 生成代码、测试代码等）
-->
<FindBugsFilter>

    <!-- 排除所有测试类 -->
    <Match>
        <Class name="~.*Test$"/>
    </Match>
    <Match>
        <Class name="~.*IT$"/>
    </Match>

    <!-- 排除 APT 生成的 TableDef 类 -->
    <Match>
        <Class name="~.*TableDef$"/>
    </Match>
    <Match>
        <Class name="~.*Tables$"/>
    </Match>

    <!-- 排除 MapStruct 生成的 Converter 实现类 -->
    <Match>
        <Class name="~.*ConverterImpl$"/>
    </Match>

    <!-- Lombok @Data 生成的 equals/hashCode 中可能触发的 EQ_COMPARETO_USE_OBJECT_EQUALS -->
    <Match>
        <Bug pattern="EQ_COMPARETO_USE_OBJECT_EQUALS"/>
    </Match>

    <!-- 忽略 DO 实体类的序列化字段警告（BaseDO 已处理） -->
    <Match>
        <Class name="~.*DO$"/>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
    </Match>

    <!-- 忽略可能的误报：Spring @Autowired 构造器注入的非 null 检查 -->
    <Match>
        <Bug pattern="NP_NONNULL_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR"/>
    </Match>

    <!-- 忽略 String.format 性能提示（可读性优先） -->
    <Match>
        <Bug pattern="VA_FORMAT_STRING_USES_NEWLINE"/>
    </Match>

    <!--
      Spring @ConfigurationProperties 对象由容器统一管理生命周期，
      在构造器中存储其引用是合理的框架用法，防御性复制无意义。
      适用于所有 BindingManager / AutoConfiguration 中注入的配置对象。
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~.*Manager$"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~.*AutoConfiguration$"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~.*Properties$"/>
    </Match>

<!--      <&#45;&#45; 排除 loadup-commons-api 模块的所有类：-->
<!--      该模块是框架级 SPI 抽象层（Binder/Binding/Cfg 接口及抽象基类），-->
<!--      由框架设计者维护，不适用常规业务代码的 SpotBugs 规则。-->
    <Match>
        <Class name="~io\.github\.loadup\.framework\.api\..*"/>
    </Match>

    <!--
      排除 loadup-commons-dto 模块的所有类：
      DTO/Query/Response 是数据传输对象，设计上就是可变的，
      EI_EXPOSE_REP 对 DTO 是误报（防御性复制对传输对象是过度工程）。
    -->
    <Match>
        <Class name="~io\.github\.loadup\.commons\..*"/>
    </Match>

    <!--
      RedisCacheBinder.calculateRandomDuration 使用 ThreadLocalRandom 做缓存过期时间抖动（防止缓存雪崩），
      这不是安全敏感场景，PREDICTABLE_RANDOM 属于误报。
    -->
    <Match>
        <Class name="io.github.loadup.components.cache.redis.binder.RedisCacheBinder"/>
        <Bug pattern="PREDICTABLE_RANDOM"/>
    </Match>

    <!--
      SharedXxxContainer.getInstance() 返回静态单例容器实例（Testcontainers 共享容器模式），
      这是有意设计：测试容器必须被多个测试类共享引用。MS_EXPOSE_REP 是误报。
    -->
    <Match>
        <Bug pattern="MS_EXPOSE_REP"/>
        <Class name="~.*Shared.*Container$"/>
    </Match>

    <!--
      TestContainersProperties 是 Spring @ConfigurationProperties 配置对象，
      其 getter 返回嵌套配置子对象（ContainerConfig）是 Spring 注入机制的正常使用，
      EI_EXPOSE_REP（返回可变对象引用）在此是误报。
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
        <Class name="~.*Properties$"/>
    </Match>

    <!--
      captcha 组件中的 GifEncoder、Quant、FontsUtil、Randoms、Captcha 是算法实现类，
      采用 C 语言风格编写（NeuQuant 色彩量化、LZW GIF 编码），包含大量低级位运算、
      文件 I/O 操作以及 C 风格静态字段，不适用常规 Java 代码的 SpotBugs 规则。
    -->
    <Match>
        <Class name="~io\.github\.loadup\.components\.captcha\.utils\.GifEncoder"/>
    </Match>
    <Match>
        <Class name="~io\.github\.loadup\.components\.captcha\.utils\.Quant"/>
    </Match>
    <Match>
        <Class name="~io\.github\.loadup\.components\.captcha\.utils\.FontsUtil"/>
    </Match>
    <Match>
        <Class name="~io\.github\.loadup\.components\.captcha\.utils\.Encoder"/>
    </Match>
    <Match>
        <Class name="~io\.github\.loadup\.components\.captcha\.base\.Randoms"/>
        <Bug pattern="MS_PKGPROTECT,MS_SHOULD_BE_FINAL"/>
    </Match>
    <Match>
        <Class name="~io\.github\.loadup\.components\.captcha\.base\.Captcha"/>
        <Bug pattern="MS_PKGPROTECT"/>
    </Match>

    <!--
      loadup-components-dfs-api 的模型类（FileMetadata、FileUploadRequest、FileDownloadResponse）
      是 DFS 组件 API 层的数据传输对象，包含 Map<String,String> metadata 字段，
      对传输对象做防御性复制是过度工程，EI_EXPOSE_REP / EI_EXPOSE_REP2 属于误报。
      同样适用于 dfs-binder-database 的实体类（FileStorageEntity）：
      byte[] content 是数据库二进制存储字段，ORM 框架直接操作，防御性复制会浪费内存。
    -->
    <Match>
        <Class name="~io\.github\.loadup\.components\.dfs\.model\..*"/>
    </Match>
    <Match>
        <Class name="~io\.github\.loadup\.components\.dfs\.database\.entity\..*"/>
    </Match>

    <!--
      CaptchaEndpoint、TenantInterceptor、BaseEntityListener 等 Spring 组件通过构造器注入
      @ConfigurationProperties 对象（如 CaptchaProperties、DatabaseProperties），
      这是标准的 Spring DI 模式，防御性复制无意义，EI_EXPOSE_REP2 属于误报。
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="io.github.loadup.components.captcha.config.CaptchaEndpoint"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~.*Interceptor$"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~.*Listener$"/>
    </Match>

    <!--
      LocalDfsBinder.download() 有意返回一个开放的 InputStream 给调用方（Streaming Download 模式），
      由调用方负责关闭。OBL_UNSATISFIED_OBLIGATION 在此是误报。
      REC_CATCH_EXCEPTION 在此是必要的：upload 中封装了 NoSuchAlgorithmException + IOException，
      通过统一的 RuntimeException 向上传递。
      PATH_TRAVERSAL_IN：所有路径操作均通过 validatePath() 方法验证在 basePath 范围内，
      FindSecBugs taint 分析无法追踪运行时验证，误报。
    -->
    <Match>
        <Class name="io.github.loadup.components.dfs.local.binder.LocalDfsBinder"/>
        <Bug pattern="OBL_UNSATISFIED_OBLIGATION,REC_CATCH_EXCEPTION,PATH_TRAVERSAL_IN"/>
    </Match>

    <!--
      DatabaseDfsBinder 使用的 SQL 模板通过 String.format 插入表名（tableName），
      表名来自 @ConfigurationProperties（application.yml），在 afterConfigInjected 中已通过
      正则表达式 [a-zA-Z_][a-zA-Z0-9_]* 验证，排除了 SQL 注入风险。
      FindSecBugs taint 分析无法识别运行时的表名校验，SQL_INJECTION_SPRING_JDBC 属于误报。
      REC_CATCH_EXCEPTION 同 LocalDfsBinder，封装了 IOException + NoSuchAlgorithmException。
    -->
    <Match>
        <Class name="io.github.loadup.components.dfs.database.binder.DatabaseDfsBinder"/>
        <Bug pattern="SQL_INJECTION_SPRING_JDBC,REC_CATCH_EXCEPTION,EI_EXPOSE_REP"/>
    </Match>

    <!--
      S3DfsBinder.upload() catch(Exception) 封装了 S3 SDK 检查异常 + IOException，
      通过统一的 RuntimeException 向上传递，REC_CATCH_EXCEPTION 属于误报。
    -->
    <Match>
        <Class name="io.github.loadup.components.dfs.s3.binder.S3DfsBinder"/>
        <Bug pattern="REC_CATCH_EXCEPTION"/>
    </Match>

    <!--
      Spring 构造器注入（@RequiredArgsConstructor / @Autowired）会将 Spring Bean 引用
      （JdbcTemplate、Properties、Mapper 等）存入字段。这是 Spring 标准的 DI 模式，
      所有 Bean 均由 Spring 容器管理生命周期，防御性复制无意义，EI_EXPOSE_REP2 是误报。
      同样适用于 loadup 模块内的 DTO/Model/Entity 类（数据传输对象不需要防御性复制）。
      EI_EXPOSE_REP（getter 返回可变引用）：对 List/Map 做防御性复制对 API 模型类是过度工程。
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~io\.github\.loadup\..*"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.github\.loadup\..*"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
        <Class name="~io\.github\.loadup\..*"/>
    </Match>
    <!--
      GlobalUniqueMapper 在 getTableName() 中已通过正则验证表名，
      FindSecBugs taint 分析不追踪此验证，SQL_INJECTION_SPRING_JDBC 是误报。
    -->
    <Match>
        <Class name="io.github.loadup.components.globalunique.mapper.GlobalUniqueMapper"/>
        <Bug pattern="SQL_INJECTION_SPRING_JDBC"/>
    </Match>

    <!--
      SMS Provider 中的 ThreadLocalRandom 用于模拟成功率（测试/模拟场景），
      不是安全敏感用途，PREDICTABLE_RANDOM 是误报。
    -->
    <Match>
        <Class name="~io\.github\.loadup\.components\.gotone\.channel\.sms\..*"/>
        <Bug pattern="PREDICTABLE_RANDOM"/>
    </Match>

</FindBugsFilter>

