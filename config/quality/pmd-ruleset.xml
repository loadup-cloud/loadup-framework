<?xml version="1.0" encoding="UTF-8"?>
<!--
  PMD 规则集配置 - LoadUp 项目定制规则
  文档: https://pmd.github.io/pmd/pmd_rules_java.html
-->
<ruleset name="LoadUp PMD Rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.net/ruleset_2_0_0.xsd">

    <description>LoadUp 项目 PMD 规则集</description>

    <!--
      排除 loadup-commons-api 模块：
      该模块是框架级 SPI 抽象层（Binder/Binding/Cfg 接口及抽象基类），
      使用了大量泛型、模板方法、框架内部规范，不适用标准业务代码的 PMD 规则。
    -->
    <exclude-pattern>.*/loadup-commons-api/.*</exclude-pattern>
    <exclude-pattern>.*/framework/api/.*</exclude-pattern>

    <!--
      排除 loadup-commons-dto 模块：
      DTO/Query/Response 是纯数据传输对象，DataClass 等规则对其是误报。
    -->
    <exclude-pattern>.*/loadup-commons-dto/.*</exclude-pattern>
    <exclude-pattern>.*/commons/result/.*</exclude-pattern>
    <exclude-pattern>.*/commons/request/.*</exclude-pattern>

    <!--
      排除 loadup-commons-util 模块：
      工具类使用了大量静态方法、参数重赋值、宽泛异常捕获等工具类惯用模式，
      这些是工具库的合理设计，不适用业务代码的 PMD 规则。
    -->
    <exclude-pattern>.*/loadup-commons-util/.*</exclude-pattern>
    <exclude-pattern>.*/commons/util/.*</exclude-pattern>

    <!-- ===== Best Practices ===== -->
    <rule ref="category/java/bestpractices.xml">
        <!-- 允许测试类使用 JUnit 4 风格（对应 JUnit 5 迁移中的兼容场景） -->
        <exclude name="JUnit4TestShouldUseTestAnnotation"/>
        <exclude name="JUnit4SuitesShouldUseSuiteAnnotation"/>
        <!-- Lombok @Builder 生成的 toString 可能触发，排除 -->
        <exclude name="UseCollectionIsEmpty"/>
        <!-- Spring DI 构造器注入时 @Autowired 字段警告，排除（已有 Checkstyle 规则约束） -->
        <exclude name="LooseCoupling"/>
        <!-- 允许在测试断言中使用 assertEquals（JUnit4 对应规则在 PMD 7.x 中已移除） -->
        <!--
          SLF4J 的占位符本身已是懒加载，无需 if(log.isDebugEnabled()) 守卫。
          强制守卫会使代码冗长且没有实质收益。
        -->
        <exclude name="GuardLogStatement"/>
        <!--
          项目中使用 interface 常量（CacheConstants 等）作为类型安全的命名空间，
          这是项目约定的设计模式，不是 "常量接口" 滥用。
        -->
        <exclude name="ConstantsInInterface"/>
        <!-- 允许 catch(GenericException) — pipeline/executor 层会显式捕获 -->
        <exclude name="AvoidCatchingGenericException"/>
    </rule>

    <!-- ===== Code Style ===== -->
    <rule ref="category/java/codestyle.xml">
        <!-- 排除对变量命名的过度限制 -->
        <exclude name="ShortVariable"/>
        <exclude name="LongVariable"/>
        <exclude name="ShortMethodName"/>
        <exclude name="ShortClassName"/>
        <!-- 允许 Java 21 record/sealed 等新特性 -->
        <exclude name="LocalVariableCouldBeFinal"/>
        <exclude name="MethodArgumentCouldBeFinal"/>
        <!-- 允许 Lombok 注解的 @Builder 等 -->
        <exclude name="AtLeastOneConstructor"/>
        <exclude name="OnlyOneReturn"/>
        <exclude name="CallSuperInConstructor"/>
        <exclude name="CommentDefaultAccessModifier"/>
        <exclude name="DefaultPackage"/>
        <exclude name="TooManyStaticImports"/>
        <!-- Palantir 格式化风格不强制 -->
        <exclude name="UnnecessaryConstructor"/>
        <!--
          Pipeline/Extension API 使用描述性泛型名称（REQ, DATA, RES, CTX）以提升可读性，
          单字母命名（T, E, R）对业务 API 可读性较差。
        -->
        <exclude name="GenericsNaming"/>
        <!--
          项目大量使用 Fluent Builder（setXxx 返回 this），
          这是有意为之的链式 API 设计，不是语义错误。
        -->
        <exclude name="LinguisticNaming"/>
        <!-- 枚举/类内部对自身类名的完全限定引用，可读性无害 -->
        <exclude name="UnnecessaryFullyQualifiedName"/>
    </rule>

    <!-- ===== Design ===== -->
    <rule ref="category/java/design.xml">
        <!-- 排除规模较大的 Service 复杂度限制（业务编排服务） -->
        <exclude name="TooManyMethods"/>
        <exclude name="TooManyFields"/>
        <exclude name="ExcessivePublicCount"/>
        <exclude name="GodClass"/>
        <exclude name="LawOfDemeter"/>
        <exclude name="LoosePackageCoupling"/>
        <!-- AutoConfiguration 类允许有多个 Bean -->
        <exclude name="CyclomaticComplexity"/>
        <exclude name="NPathComplexity"/>
        <exclude name="CouplingBetweenObjects"/>
        <!--
          Abstract base classes without abstract methods are used as template-method base
          classes (e.g. CacheBinderCfg, AbstractPipelineBuilder). The abstract keyword
          intentionally prevents direct instantiation — this is correct OOP.
        -->
        <exclude name="AbstractClassWithoutAbstractMethod"/>
        <exclude name="AbstractClassWithoutAnyMethod"/>
        <!--
          PipelineSpec, GatewayContext, etc. are intentional data-holder/spec objects.
          DataClass rule is noise for these structural patterns.
        -->
        <exclude name="DataClass"/>
        <!--
          Pipeline executor intentionally re-throws caught exceptions via sneakyThrow.
          This is not a control-flow misuse but a deliberate checked-exception bypass.
        -->
        <exclude name="ExceptionAsFlowControl"/>
        <!--
          CognitiveComplexity is already covered by the broader CyclomaticComplexity exclusion;
          aligning for consistency.
        -->
        <exclude name="CognitiveComplexity"/>
        <!--
          Marker/sentinel classes (EndTxMarker) intentionally have a private constructor
          and no static members — they exist only as type tokens in generics/instanceof checks.
        -->
        <exclude name="MissingStaticMethodInNonInstantiatableClass"/>
        <!--
          PMD 7.x moved AvoidCatchingGenericException from bestpractices/errorprone to design.
          crypto/JCA APIs only declare checked sub-types of GeneralSecurityException;
          catching Exception is the only practical way to guard against undocumented RuntimeExceptions.
          Same exclusion already present in bestpractices and errorprone for backward compatibility.
        -->
        <exclude name="AvoidCatchingGenericException"/>
        <!--
          PMD 7.x moved AvoidThrowingRawExceptionTypes from errorprone to design.
          Already excluded from errorprone; kept consistent here.
          Some framework integration points (Flyway init, entity listeners) must wrap
          arbitrary third-party exceptions before the typed exception hierarchy is available.
        -->
        <exclude name="AvoidThrowingRawExceptionTypes"/>
        <!--
          AvoidRethrowingException: the pattern "catch(SpecificException e) { throw e; }"
          is used deliberately to distinguish typed exceptions from generic fallback handlers.
          Removing the catch would merge the specific and generic paths.
        -->
        <exclude name="AvoidRethrowingException"/>
        <!--
          UseObjectForClearerAPI: service APIs like insertAndCheck(key, bizType, bizId, requestData)
          intentionally expose individual String parameters to keep callers lightweight
          (no additional DTO required for simple idempotency checks).
        -->
        <exclude name="UseObjectForClearerAPI"/>
    </rule>

    <!-- ===== Error Prone ===== -->
    <rule ref="category/java/errorprone.xml">
        <exclude name="BeanMembersShouldSerialize"/>
        <exclude name="DataflowAnomalyAnalysis"/>
        <exclude name="MissingSerialVersionUID"/>
        <!-- 允许在 catch 中 throw 新异常 (kept for backward compat; rule now lives in design.xml) -->
        <exclude name="AvoidCatchingGenericException"/>
        <exclude name="AvoidThrowingRawExceptionTypes"/>
        <!--
          PipelineExecutor must catch Throwable to implement the finally-stage guarantee
          and route errors to ExceptionHandlerBus regardless of Error vs Exception.
        -->
        <exclude name="AvoidCatchingThrowable"/>
        <!--
          @SuppressWarnings("unchecked") / @SuppressWarnings("rawtypes") strings are
          annotation literals, not magic strings — AvoidDuplicateLiterals is a false positive.
        -->
        <exclude name="AvoidDuplicateLiterals"/>
        <!--
          Spring Boot @ConfigurationProperties beans and framework-level base classes
          set defaults by calling inherited Lombok-generated setters from their constructors.
          This pattern is intentional and safe — the setter is a trivial field assignment
          and will never be overridden with side-effecting logic.
        -->
        <exclude name="ConstructorCallsOverridableMethod"/>
    </rule>

    <!-- ===== Multithreading ===== -->
    <rule ref="category/java/multithreading.xml">
        <exclude name="UseConcurrentHashMap"/>
        <exclude name="DoNotUseThreads"/>
        <!--
          ExtensionRegistry uses `volatile boolean initialized` for a standard
          double-checked locking pattern. Banning volatile here would break thread safety.
        -->
        <exclude name="AvoidUsingVolatile"/>
    </rule>

    <!-- ===== Performance ===== -->
    <rule ref="category/java/performance.xml">
        <exclude name="AvoidInstantiatingObjectsJustToGetClass"/>
        <exclude name="InsufficientStringBufferDeclaration"/>
        <!--
          PipelineExecutor creates a TransactionTemplate per TX-block iteration
          (each block may declare different propagation), and ExtensionRegistry builds
          ScenarioKey instances during startup warmup — both are intentional.
        -->
        <exclude name="AvoidInstantiatingObjectsInLoops"/>
        <!--
          PMD 7.x moved RedundantFieldInitializer from codestyle to performance.
          Explicit = false / = null / = 0 initializers are kept for documentation clarity —
          they make the intended default value obvious to the reader without relying on
          JVM-specified zero-values.
        -->
        <exclude name="RedundantFieldInitializer"/>
    </rule>

    <!-- ===== Security ===== -->
    <rule ref="category/java/security.xml"/>

</ruleset>

